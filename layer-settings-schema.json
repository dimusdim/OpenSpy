{
  "$schema": "User-facing layer settings — hierarchical tree for UI, map layers only",
  "_design": {
    "master_record": "sources-catalog.json — source of truth for what exists and how it's visualized",
    "this_file": "defines user-facing grouping tree for the settings panel. Only map layers — widgets and UI tools (oil prices, AI image) are NOT here, they have their own toggle buttons in the toolbar",
    "tree_depth": "domain → layer → subtype. Each level is independently toggleable"
  },

  "tree": [
    {
      "id": "air",
      "title": "Air Domain",
      "icon": "plane",
      "children": [
        {
          "id": "aircraft",
          "title": "Aircraft Tracking",
          "catalog_layer": "Aircraft",
          "enabled_by_default": true,
          "sources": [
            {
              "source_id": "opensky",
              "title": "OpenSky Network",
              "data_type": "real-time",
              "refresh": "90s",
              "auth": [
                { "key": "OPENSKY_USERNAME", "label": "Username", "type": "text", "required": true, "signup_url": "https://opensky-network.org" },
                { "key": "OPENSKY_PASSWORD", "label": "Password", "type": "password", "required": true }
              ]
            }
          ],
          "subtypes": [
            { "id": "airliner", "title": "Airliners", "enabled": true, "color": "#ffffff" },
            { "id": "military", "title": "Military Aircraft", "enabled": true, "color": "#facc15" },
            { "id": "light", "title": "Light / GA", "enabled": true, "color": "#60a5fa" },
            { "id": "general", "title": "General Aviation", "enabled": true, "color": "#e5e7eb" }
          ],
          "enrichment": [
            { "id": "aircraft_photo", "title": "Aircraft Photos", "enabled": true },
            { "id": "aircraft_route", "title": "Route Info", "enabled": true }
          ]
        },
        {
          "id": "airspace",
          "title": "Restricted Airspace",
          "catalog_layer": "Airspace",
          "enabled_by_default": false,
          "sources": [
            {
              "source_id": "openaip",
              "title": "OpenAIP",
              "data_type": "semi-static",
              "refresh": "1h",
              "auth": [
                { "key": "OPENAIP_API_KEY", "label": "API Key", "type": "password", "required": true, "signup_url": "https://www.openaip.net/" }
              ]
            }
          ],
          "subtypes": [
            { "id": "restricted", "title": "Restricted", "enabled": true, "color": "#ef4444" },
            { "id": "danger", "title": "Danger", "enabled": true, "color": "#f97316" },
            { "id": "prohibited", "title": "Prohibited", "enabled": true, "color": "#991b1b" },
            { "id": "alert", "title": "Alert", "enabled": true, "color": "#eab308" },
            { "id": "warning", "title": "Warning", "enabled": true, "color": "#d97706" }
          ]
        },
        {
          "id": "jamming",
          "title": "GNSS Jamming Zones",
          "catalog_layer": "Jamming",
          "enabled_by_default": true,
          "sources": [
            {
              "source_id": "gpsjam",
              "title": "GPSJam.org (ADS-B NIC analysis)",
              "data_type": "daily",
              "refresh": "6h",
              "auth": []
            }
          ],
          "subtypes": [
            { "id": "high", "title": "Severe (>50%)", "enabled": true, "color": "#ef4444" },
            { "id": "medium", "title": "Moderate (20-50%)", "enabled": true, "color": "#f97316" },
            { "id": "low", "title": "Low (5-20%)", "enabled": true, "color": "#eab308" }
          ]
        }
      ]
    },

    {
      "id": "maritime",
      "title": "Maritime Domain",
      "icon": "anchor",
      "children": [
        {
          "id": "vessels",
          "title": "Vessel Tracking",
          "catalog_layer": "Vessel",
          "enabled_by_default": true,
          "sources": [
            {
              "source_id": "aisstream",
              "title": "AISStream (AIS WebSocket)",
              "data_type": "real-time",
              "refresh": "continuous",
              "auth": [
                { "key": "AISSTREAM_API_KEY", "label": "API Key", "type": "password", "required": true, "signup_url": "https://aisstream.io/" }
              ]
            }
          ],
          "subtypes": [
            { "id": "cargo", "title": "Cargo", "enabled": true, "color": "#e5e7eb" },
            { "id": "tanker", "title": "Tanker", "enabled": true, "color": "#ef4444" },
            { "id": "passenger", "title": "Passenger", "enabled": true, "color": "#3b82f6" },
            { "id": "fishing", "title": "Fishing", "enabled": true, "color": "#84cc16" },
            { "id": "military", "title": "Military", "enabled": true, "color": "#64748b" },
            { "id": "unknown", "title": "Unknown", "enabled": true, "color": "#9ca3af" }
          ]
        },
        {
          "id": "maritime_anomalies",
          "title": "Maritime Anomalies",
          "note": "Dark vessels and suspicious activity — two detection systems for one phenomenon",
          "children": [
            {
              "id": "dark_vessels",
              "title": "AIS Silent (Own Detection)",
              "catalog_layer": "Dark Vessel",
              "enabled_by_default": true,
              "sources": [
                {
                  "source_id": "aisstream_dark",
                  "title": "AIS gap detection (>1h silent)",
                  "data_type": "derived",
                  "auth": []
                }
              ],
              "subtypes": [
                { "id": "dark_vessel", "title": "Silent Vessel", "enabled": true, "color": "#dc2626" }
              ]
            },
            {
              "id": "gfw_events",
              "title": "Fishing Watch Events",
              "catalog_layer": "GFW",
              "enabled_by_default": false,
              "sources": [
                {
                  "source_id": "gfw",
                  "title": "Global Fishing Watch",
                  "data_type": "near-real-time",
                  "refresh": "1h",
                  "auth": [
                    { "key": "GFW_TOKEN", "label": "Bearer Token", "type": "password", "required": true, "signup_url": "https://globalfishingwatch.org/our-apis/tokens" }
                  ]
                }
              ],
              "subtypes": [
                { "id": "gap", "title": "AIS Gap Events", "enabled": true, "color": "#a855f7" }
              ],
              "visual_issue": "GFW uses single purple diamond for ALL event types. Could differentiate: gap, encounter, loitering, port_visit"
            }
          ]
        }
      ]
    },

    {
      "id": "space",
      "title": "Space Domain",
      "icon": "satellite",
      "children": [
        {
          "id": "satellites",
          "title": "Satellite Tracking",
          "catalog_layer": "Satellite",
          "enabled_by_default": true,
          "sources": [
            {
              "source_id": "spacetrack",
              "title": "Space-Track.org (US Space Command, primary)",
              "data_type": "cached",
              "refresh": "24h",
              "auth": [
                { "key": "SPACETRACK_EMAIL", "label": "Email", "type": "text", "required": false, "signup_url": "https://www.space-track.org/auth/createAccount" },
                { "key": "SPACETRACK_PASSWORD", "label": "Password", "type": "password", "required": false }
              ],
              "note": "Optional primary source. Falls back to CelesTrak → Ivan TLE if not configured."
            },
            {
              "source_id": "celestrak",
              "title": "CelesTrak (mirror, auto-fallback)",
              "data_type": "cached",
              "refresh": "24h",
              "auth": [],
              "note": "Public mirror. Rate-limits aggressively — may get 403 bans."
            },
            {
              "source_id": "ivan_tle",
              "title": "tle.ivanstanojevic.me (last resort fallback)",
              "data_type": "cached",
              "auth": [],
              "note": "Free JSON API. Used only if Space-Track and CelesTrak both fail."
            },
            {
              "source_id": "spectator_earth",
              "title": "Spectator Earth (sensor specs)",
              "data_type": "enrichment",
              "refresh": "24h",
              "auth": [
                { "key": "SPECTATOR_EARTH_API_KEY", "label": "API Key", "type": "password", "required": false, "signup_url": "https://app.spectator.earth/" }
              ]
            }
          ],
          "subtypes": [
            { "id": "military", "title": "Military", "enabled": true, "color": "#ef4444" },
            { "id": "recon", "title": "Reconnaissance", "enabled": true, "color": "#d946ef" },
            { "id": "commercial", "title": "Commercial", "enabled": true, "color": "#06b6d4" },
            { "id": "civilian", "title": "Civilian", "enabled": true, "color": "#84cc16" }
          ],
          "extra_toggles": [
            { "id": "satellite_footprints", "title": "Sensor Footprint Cones", "enabled": true },
            { "id": "satellite_trails", "title": "Orbital Trails (±2h)", "enabled": true }
          ]
        }
      ]
    },

    {
      "id": "ground_events",
      "title": "Ground Events",
      "icon": "alert-triangle",
      "children": [
        {
          "id": "conflicts",
