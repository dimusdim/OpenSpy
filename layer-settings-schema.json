          "enabled_by_default": true,
          "sources": [
            {
              "source_id": "acled",
              "title": "ACLED",
              "data_type": "near-real-time",
              "refresh": "30 min (last 7 days)",
              "auth": [
                { "key": "ACLED_EMAIL", "label": "Email", "type": "text", "required": true, "signup_url": "https://developer.acleddata.com/" },
                { "key": "ACLED_KEY", "label": "API Key", "type": "password", "required": true }
              ]
            }
          ],
          "subtypes": [
            { "id": "explosions", "title": "Explosions / Remote Violence", "enabled": true, "color": "#ef4444" },
            { "id": "battles", "title": "Battles", "enabled": true, "color": "#f97316" },
            { "id": "assaults", "title": "Assaults", "enabled": true, "color": "#fb7185" },
            { "id": "mass_violence", "title": "Mass Violence", "enabled": true, "color": "#e11d48" },
            { "id": "protests", "title": "Protests", "enabled": true, "color": "#fde047" },
            { "id": "threats", "title": "Threats", "enabled": true, "color": "#f59e0b" },
            { "id": "force_posture", "title": "Force Posture", "enabled": true, "color": "#a855f7" },
            { "id": "coercion", "title": "Coercion", "enabled": true, "color": "#f97316" }
          ]
        },
        {
          "id": "disasters",
          "title": "Natural Disasters",
          "catalog_layer": "Disasters",
          "enabled_by_default": true,
          "sources": [
            { "source_id": "gdacs", "title": "GDACS (UN/EC Alerts)", "auth": [] },
            { "source_id": "usgs", "title": "USGS Earthquakes", "auth": [] },
            { "source_id": "eonet", "title": "NASA EONET", "auth": [] }
          ],
          "subtypes": [
            { "id": "EQ", "title": "Earthquakes", "enabled": true, "color": "#ef4444" },
            { "id": "TC", "title": "Tropical Cyclones", "enabled": true, "color": "#f97316" },
            { "id": "FL", "title": "Floods", "enabled": true, "color": "#3b82f6" },
            { "id": "VO", "title": "Volcanoes", "enabled": true, "color": "#f97316" },
            { "id": "WF", "title": "Wildfires", "enabled": true, "color": "#ef4444" },
            { "id": "DR", "title": "Droughts", "enabled": true, "color": "#eab308" }
          ],
          "data_overlap": "WF subtype overlaps with Fire layer (FIRMS). GDACS/EONET show event-level markers, FIRMS shows individual hotspot detections"
        },
        {
          "id": "fires",
          "title": "Fire Hotspot Detection",
          "catalog_layer": "Fire",
          "enabled_by_default": true,
          "sources": [
            { "source_id": "firms", "title": "NASA FIRMS (VIIRS satellite)", "data_type": "near-real-time", "refresh": "30 min", "auth": [] }
          ],
          "subtypes": [
            { "id": "high", "title": "High FRP (>100 MW)", "enabled": true, "color": "#ef4444" },
            { "id": "medium", "title": "Medium FRP (30-100 MW)", "enabled": true, "color": "#f97316" },
            { "id": "low", "title": "Low FRP (<30 MW)", "enabled": true, "color": "#eab308" }
          ],
          "data_overlap": "Overlaps with Disasters WF subtype. Different granularity: FIRMS = 60K individual hotspot points, Disasters WF = named wildfire events with impact zones"
        }
      ]
    },

