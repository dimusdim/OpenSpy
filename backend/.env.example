# === Required for core data streams ===
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
AISSTREAM_API_KEY=
OPENROUTER_API_KEY=

# === Optional: Block 2 API keys (services gracefully skip if empty) ===
TOMTOM_API_KEY=
HERE_API_KEY=
WINDY_API_KEY=
ACLED_EMAIL=
# Default ACLED path is legacy access-key mode with ACLED_EMAIL + ACLED_KEY.
# Password OAuth is opt-in only: set ACLED_AUTH_MODE=oauth or
# ACLED_ENABLE_PASSWORD_OAUTH=true after confirming your ACLED account supports it.
ACLED_PASSWORD=
ACLED_KEY=
ACLED_AUTH_MODE=
ACLED_ENABLE_PASSWORD_OAUTH=false
OPENAIP_API_KEY=
GFW_TOKEN=
CLOUDFLARE_API_TOKEN=
FIRMS_MAP_KEY=
NASA_FIRMS_MAP_KEY=
SPACETRACK_EMAIL=
SPACETRACK_PASSWORD=
SPECTATOR_EARTH_API_KEY=
WIGLE_API_NAME=
WIGLE_API_TOKEN=
EIA_API_KEY=
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
ROAD511_API_KEY=
NASA_DIP_TOKEN=

# === Optional local agent providers ===
# OpenSpy can launch a local product agent through an installed CLI harness.
# It inherits the user's local Codex/Claude Code authentication and model setup.
AGENT_ENABLE_CODEX_PROVIDER=true
AGENT_CODEX_COMMAND=codex
AGENT_CLAUDE_COMMAND=claude
AGENT_API_TOKEN=
AI_WORLDVIEW_AGENT_TOKEN=
OPENSPY_AGENT_RUNTIME_DIR=
OPENSPY_AGENT_HARNESS_ROOT=

# === Provider source-fetch safety defaults ===
# Keep user-triggered provider fetches narrow and independent from replay speed.
CLOUDFLARE_MIN_REQUEST_INTERVAL_MS=60000
CLOUDFLARE_OUTAGE_PAGE_SIZE=100
CLOUDFLARE_OUTAGE_MAX_PAGES=50
COPERNICUS_MIN_REQUEST_INTERVAL_MS=2500
COPERNICUS_SEARCH_CACHE_SECONDS=600
COPERNICUS_RENDER_CACHE_SECONDS=3600
COPERNICUS_MAX_SEARCH_WINDOW_DAYS=14
COPERNICUS_MAX_BBOX_AREA_DEG2=25
COPERNICUS_MAX_SEARCH_RESULTS=10
COPERNICUS_MAX_RENDER_PIXELS=1024
ACLED_PAGE_SIZE=5000
ACLED_MAX_PAGES=100
ACLED_BOOTSTRAP_LOOKBACK_DAYS=7
ACLED_INCREMENTAL_OVERLAP_HOURS=6

# === Storage foundation (local-first canonical runtime) ===
# Default dev flow uses project-managed PostgreSQL/PostGIS with data/log/run
# files in .local/postgres/ and enables DB automatically via backend scripts.
# These vars remain override points for non-default launches.
POSTGRES_ENABLED=true
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/openspy
DB_APP_NAME=openspy-backend

# === OpenTelemetry (optional local observability) ===
OTEL_ENABLED=false
OTEL_SERVICE_NAME=openspy-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_METRIC_EXPORT_INTERVAL_MS=10000
OTEL_DEBUG=false

# === Overture Maps (Task 7 hybrid infra backend) ===
# Opt-in. When true, the backend runs DuckDB+httpfs queries against
# Overture's public S3 bucket in parallel with Overpass and merges the
# two result sets on every /api/infrastructure and /api/power-infra
# request. Requires `duckdb` npm package to be installed (native binary
# build, ~20 MB). When false or unset, Overpass is the sole source and
# the OvertureService is a no-op.
OVERTURE_ENABLED=false
# Pin the release version so schema assumptions stay stable across
# deploys. Overture releases monthly; bump to pick up new data.
OVERTURE_VERSION=2025-05-21.0
